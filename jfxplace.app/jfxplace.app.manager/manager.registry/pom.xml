<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>com.treilhes.jfxplace</groupId>
    <artifactId>jfxplace.app.manager</artifactId>
    <version>${manager.version}</version>
  </parent>
  <artifactId>manager.registry</artifactId>
  
  <build>
        <plugins>
            <plugin>
                <groupId>com.treilhes.emc4j</groupId>
                <artifactId>emc4j-registry-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>generate-registry-resources</id>
                        <phase>generate-resources</phase>
                        <goals>
                            <goal>emc4jRegistry</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <format>json</format>
                    <registry>
                    	<uuid>4a898b37-d2f7-437a-b4b1-5bd337e5abcf</uuid>
                    	<description>
							<image>jfxplace_apps_256x256.png</image>
							<title>jfxplace applications and plugins Registry</title>
							<text>Contains all applications and plugins mandotory for running</text>
						</description>
                        <applications>
                            <application>
                                <uuid>00000000-0000-0000-0000-000000000002</uuid>
                                <splash>manager_256x256.jpeg</splash>
                                <dependency>
                                    <groupId>com.treilhes.jfxplace</groupId>
                                    <artifactId>manager.api</artifactId>
                                    <version>${manager.version}</version>
                                </dependency>
                                <description>
                                    <image>manager_256x256.jpeg</image>
                                    <title>jfxplace Manager</title>
                                    <text>Manage installation of applications and plugins for jfxplace</text>
                                </description>
                                <extensions>
                                    <extension>
                                        <uuid>703493dd-e56f-491c-8517-feeff54407d5</uuid>
                                        <dependency>
                                            <groupId>com.treilhes.jfxplace</groupId>
                                            <artifactId>manager.app</artifactId>
                                            <version>${manager.version}</version>
                                        </dependency>
                                    </extension>
                                    <extension>
                                        <uuid>26a4c220-7adb-4fae-a9be-4c4bf233b812</uuid>
                                        <dependency>
                                            <groupId>com.treilhes.jfxplace</groupId>
                                            <artifactId>manager.store</artifactId>
                                            <version>${manager.version}</version>
                                        </dependency>
                                    </extension>
                                    <extension>
                                        <uuid>c1e38085-c20a-4481-8b91-ab9d7efec171</uuid>
                                        <dependency>
                                            <groupId>com.treilhes.jfxplace</groupId>
                                            <artifactId>manager.registries</artifactId>
                                            <version>${manager.version}</version>
                                        </dependency>
                                    </extension>
                                    <extension>
                                        <uuid>fa80ba52-4350-4155-b968-1d1f69c9c5eb</uuid>
                                        <dependency>
                                            <groupId>com.treilhes.jfxplace</groupId>
                                            <artifactId>manager.mvnrepos</artifactId>
                                            <version>${manager.version}</version>
                                        </dependency>
                                    </extension>
                                </extensions>
                            </application>
                        </applications>
                    </registry>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>