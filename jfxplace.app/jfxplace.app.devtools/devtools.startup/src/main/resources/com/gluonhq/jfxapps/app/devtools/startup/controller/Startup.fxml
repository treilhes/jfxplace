<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="scrollPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <content>
      <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
         <children>
            <HBox alignment="BOTTOM_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0" VBox.vgrow="NEVER">
               <children>
                  <Label text="Filter pattern :" />
                  <TextField fx:id="filterText" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#applyFilter" text="Apply" />
                  <Button mnemonicParsing="false" onAction="#clearFilter" text="Clear" />
                  <Button mnemonicParsing="false" onAction="#exportToFile" text="Export" />
                  <Label fx:id="globalSums" text="Label" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <VBox fx:id="result" prefHeight="200.0" prefWidth="100.0" />
         </children>
      </VBox>
   </content>
</ScrollPane>
